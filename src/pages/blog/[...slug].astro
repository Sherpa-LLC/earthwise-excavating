---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, author, metaDescription, heroImage, heroAlt, category, readingTime } = post.data;
const { Content } = await render(post);

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={metaDescription}
  image={heroImage}
  schemaType="blog-post"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: title, url: `/blog/${post.id}` },
  ]}
  blogPost={{ title, description: metaDescription, date, author, image: heroImage }}
>
  <!-- HERO -->
  {heroImage && (
    <section class="relative py-36 lg:py-44 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={heroImage}
          alt={heroAlt || title}
          class="w-full h-full object-cover"
          width="1920"
          height="1080"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(13,13,14,0.82) 0%, rgba(13,13,14,0.72) 50%, rgba(13,13,14,0.9) 100%);"></div>
      </div>
      <div class="absolute inset-0 topo-pattern" style="opacity: 0.6;"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-6 lg:px-8">
        <nav class="mb-6 text-xs uppercase tracking-widest" style="color: var(--color-text-on-dark-muted); font-family: var(--font-family-display);">
          <a href="/" class="hover:text-[var(--color-primary)] transition-colors">Home</a>
          <span class="mx-2 opacity-40">/</span>
          <a href="/blog" class="hover:text-[var(--color-primary)] transition-colors">Blog</a>
          <span class="mx-2 opacity-40">/</span>
          <span style="color: var(--color-text-on-dark);">{title}</span>
        </nav>
        {category && (
          <span class="inline-block px-3 py-1 text-[10px] font-bold rounded-sm text-white mb-4 uppercase tracking-widest" style="background: var(--color-accent); font-family: var(--font-family-display);">
            {category}
          </span>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-5" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); line-height: 1.08; text-transform: uppercase;">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-xs uppercase tracking-widest" style="color: var(--color-text-on-dark-muted); font-family: var(--font-family-display);">
          <span>{formattedDate}</span>
          {readingTime && (
            <>
              <span style="color: var(--color-earth-topsoil); opacity: 0.5;">&middot;</span>
              <span>{readingTime}</span>
            </>
          )}
          <span style="color: var(--color-earth-topsoil); opacity: 0.5;">&middot;</span>
          <span>By {author}</span>
        </div>
      </div>
      <!-- Earth strip -->
      <div class="absolute bottom-0 left-0 right-0 z-10 flex" style="height: 4px;">
        <div class="flex-1" style="background: var(--color-earth-topsoil);"></div>
        <div class="flex-1" style="background: var(--color-earth-clay);"></div>
        <div class="flex-1" style="background: var(--color-earth-rock);"></div>
        <div class="flex-1" style="background: var(--color-earth-deep);"></div>
      </div>
    </section>
  )}

  <!-- ARTICLE -->
  <article class="py-20 lg:py-28 topo-pattern-light" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-5 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-accent); --tw-prose-bold: var(--color-text);">
        <Content />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="relative py-20 text-center overflow-hidden topo-pattern" style="background: var(--color-dark);">
    <div class="absolute top-0 left-0 right-0 flex" style="height: 4px;">
      <div class="flex-1" style="background: var(--color-earth-deep);"></div>
      <div class="flex-1" style="background: var(--color-earth-rock);"></div>
      <div class="flex-1" style="background: var(--color-earth-clay);"></div>
      <div class="flex-1" style="background: var(--color-earth-topsoil);"></div>
      <div class="flex-1" style="background: var(--color-primary);"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-3xl px-5 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-5" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); text-transform: uppercase;">
        Ready to Break Ground?
      </h2>
      <p class="mb-10" style="color: var(--color-text-on-dark-muted);">
        Contact us today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href="/blog" class="btn-ghost">&larr; Back to Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
