---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((svc) => ({
    params: { slug: svc.data.slug },
    props: { service: svc },
  }));
}

const { service } = Astro.props;
const { title, metaTitle, metaDescription, heroImage, heroAlt, shortDescription, faqs } = service.data;
const { Content } = await render(service);
---

<BaseLayout
  title={metaTitle || title}
  description={metaDescription}
  schemaType="service"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: title, url: `/services/${service.data.slug}` },
  ]}
  serviceData={{ name: title, description: shortDescription, image: heroImage }}
  faqs={faqs}
>
  <!-- HERO -->
  <section class="relative py-32 lg:py-40 overflow-hidden" style="background: var(--color-secondary);">
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt={heroAlt} class="w-full h-full object-cover" style="opacity: 0.3;" width="1920" height="1080" fetchpriority="high" />
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(13,13,14,0.8) 0%, rgba(13,13,14,0.65) 50%, rgba(13,13,14,0.88) 100%);"></div>
      </div>
    )}
    <div class="absolute inset-0 topo-pattern"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm" style="color: var(--color-text-on-dark-muted); font-family: var(--font-family-display); text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.75rem;">
        <a href="/" class="hover:text-[var(--color-primary)] transition-colors">Home</a>
        <span class="mx-2 opacity-40">/</span>
        <a href="/services" class="hover:text-[var(--color-primary)] transition-colors">Services</a>
        <span class="mx-2 opacity-40">/</span>
        <span style="color: var(--color-text-on-dark);">{title}</span>
      </nav>
      <div class="accent-rule mb-6"></div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); text-transform: uppercase;">
        {title}
      </h1>
      <p class="text-lg max-w-2xl" style="color: var(--color-text-on-dark-muted); line-height: 1.65;">
        {shortDescription}
      </p>
      <div class="mt-8">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
      </div>
    </div>
    <!-- Earth strip -->
    <div class="absolute bottom-0 left-0 right-0 z-10 flex" style="height: 4px;">
      <div class="flex-1" style="background: var(--color-earth-topsoil);"></div>
      <div class="flex-1" style="background: var(--color-earth-clay);"></div>
      <div class="flex-1" style="background: var(--color-earth-rock);"></div>
      <div class="flex-1" style="background: var(--color-earth-deep);"></div>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-20 lg:py-28 topo-pattern-light" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-5 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-accent);">
        <Content />
      </div>
    </div>
  </section>

  <!-- FAQS -->
  {faqs && faqs.length > 0 && (
    <section class="py-20 lg:py-28" style="background: var(--color-bg-alt);">
      <div class="mx-auto max-w-3xl px-5 sm:px-6 lg:px-8">
        <p class="section-label mb-3">FAQ</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-10" style="font-family: var(--font-family-display); text-transform: uppercase;">
          Common Questions About {title}
        </h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="group p-6 rounded-sm overflow-hidden" style="background: var(--color-surface); box-shadow: var(--shadow-card); border-left: 4px solid var(--color-earth-topsoil);">
              <summary class="cursor-pointer font-bold text-base flex items-center justify-between" style="font-family: var(--font-family-display); text-transform: uppercase; letter-spacing: 0.02em;">
                {faq.question}
                <span class="ml-4 text-xl group-open:rotate-45 transition-transform duration-300" style="color: var(--color-accent);">+</span>
              </summary>
              <p class="mt-4 text-sm leading-relaxed" style="color: var(--color-text-muted);">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative py-20 text-center overflow-hidden topo-pattern" style="background: var(--color-dark);">
    <div class="absolute top-0 left-0 right-0 flex" style="height: 4px;">
      <div class="flex-1" style="background: var(--color-earth-deep);"></div>
      <div class="flex-1" style="background: var(--color-earth-rock);"></div>
      <div class="flex-1" style="background: var(--color-earth-clay);"></div>
      <div class="flex-1" style="background: var(--color-earth-topsoil);"></div>
      <div class="flex-1" style="background: var(--color-primary);"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-3xl px-5 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-5" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); text-transform: uppercase;">
        Ready to Break Ground?
      </h2>
      <p class="mb-10" style="color: var(--color-text-on-dark-muted);">
        Contact us today for a free consultation about {title.toLowerCase()}.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
