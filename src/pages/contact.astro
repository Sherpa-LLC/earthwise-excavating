---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';

const { business, contact, hours } = config;

const excavationTypes = [
  'Building Pad / Grading',
  'Pond Construction',
  'Driveway',
  'Basement Excavation',
  'Drainage / Erosion Control',
  'Land Clearing',
  'Bush Hogging',
  'Storm Work',
  'Seeding / Restoration',
  'Other',
];
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${business.name}. Call ${contact.phone} or fill out our contact form for a free consultation.`}
  schemaType="contact"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }]}
>
  <!-- HERO -->
  <section class="relative py-24 lg:py-32 overflow-hidden topo-pattern" style="background: var(--color-secondary);">
    <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); text-transform: uppercase;">
        Break Ground <span style="color: var(--color-primary);">Today</span>
      </h1>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-on-dark-muted);">
        Ready to start your project? Reach out for a free, no-obligation site assessment and estimate.
      </p>
    </div>
    <!-- Earth strip -->
    <div class="absolute bottom-0 left-0 right-0 z-10 flex" style="height: 4px;">
      <div class="flex-1" style="background: var(--color-earth-topsoil);"></div>
      <div class="flex-1" style="background: var(--color-earth-clay);"></div>
      <div class="flex-1" style="background: var(--color-earth-rock);"></div>
      <div class="flex-1" style="background: var(--color-earth-deep);"></div>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-20 lg:py-28 topo-pattern-light" style="background: var(--color-bg);">
    <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- PROJECT SPECIFICATION FORM -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-2" style="font-family: var(--font-family-display); text-transform: uppercase;">
            Project Specification
          </h2>
          <p class="text-sm mb-8" style="color: var(--color-text-muted);">Tell us about your project and we'll get back to you within one business day.</p>

          <form class="space-y-6" action="/contact" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-xs font-bold uppercase tracking-widest mb-2" style="font-family: var(--font-family-display);">Name *</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-sm text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs font-bold uppercase tracking-widest mb-2" style="font-family: var(--font-family-display);">Phone</label>
                <input type="tel" id="phone" name="phone"
                  class="w-full px-4 py-3 rounded-sm text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-widest mb-2" style="font-family: var(--font-family-display);">Email *</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-sm text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                style="border: 1px solid var(--color-border); background: var(--color-surface);"
              />
            </div>

            <!-- Excavation Type Selector -->
            <div>
              <label for="project-type" class="block text-xs font-bold uppercase tracking-widest mb-2" style="font-family: var(--font-family-display);">Excavation Type *</label>
              <select id="project-type" name="project-type" required
                class="w-full px-4 py-3 rounded-sm text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                style="border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text);"
              >
                <option value="">Select project type...</option>
                {excavationTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="address" class="block text-xs font-bold uppercase tracking-widest mb-2" style="font-family: var(--font-family-display);">Project Address</label>
              <input type="text" id="address" name="address"
                class="w-full px-4 py-3 rounded-sm text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                style="border: 1px solid var(--color-border); background: var(--color-surface);"
                placeholder="Street address or nearest intersection"
              />
            </div>

            <div>
              <label for="message" class="block text-xs font-bold uppercase tracking-widest mb-2" style="font-family: var(--font-family-display);">Project Details *</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-sm text-sm transition-all duration-200 resize-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"
                style="border: 1px solid var(--color-border); background: var(--color-surface);"
                placeholder="Describe your project, timeline, budget, or any special requirements..."
              ></textarea>
            </div>

            <!-- Turnstile Placeholder -->
            <div class="cf-turnstile" data-sitekey="placeholder" data-theme="light"></div>

            <button type="submit" class="btn-primary w-full sm:w-auto">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Submit Project Request
            </button>
          </form>
        </div>

        <!-- INFO SIDEBAR -->
        <div class="lg:col-span-2 space-y-6">
          <div class="gauge-stat !bg-[var(--color-dark)]">
            <h3 class="font-bold text-sm uppercase tracking-widest mb-4" style="font-family: var(--font-family-display); color: var(--color-primary);">Call Us</h3>
            <a href={`tel:${contact.phoneRaw}`} class="text-2xl font-bold block" style="color: var(--color-text-on-dark); font-family: var(--font-family-display);">
              {contact.phone}
            </a>
            <p class="text-xs mt-2" style="color: var(--color-text-on-dark-muted);">Mon-Fri 7AM-5PM</p>
          </div>

          <div class="p-6 rounded-sm" style="background: var(--color-bg-alt); border-left: 4px solid var(--color-earth-topsoil);">
            <h3 class="font-bold text-sm uppercase tracking-widest mb-4" style="font-family: var(--font-family-display);">Email</h3>
            <a href={`mailto:${contact.email}`} class="transition-colors text-sm hover:text-[var(--color-accent)]" style="color: var(--color-accent);">
              {contact.email}
            </a>
          </div>

          <div class="p-6 rounded-sm" style="background: var(--color-bg-alt); border-left: 4px solid var(--color-earth-clay);">
            <h3 class="font-bold text-sm uppercase tracking-widest mb-4" style="font-family: var(--font-family-display);">Location</h3>
            <address class="not-italic text-sm leading-relaxed" style="color: var(--color-text-muted);">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
          </div>

          <div class="p-6 rounded-sm" style="background: var(--color-bg-alt); border-left: 4px solid var(--color-earth-rock);">
            <h3 class="font-bold text-sm uppercase tracking-widest mb-4" style="font-family: var(--font-family-display);">Hours</h3>
            <dl class="space-y-1 text-sm">
              {Object.entries(hours).map(([day, h]) => (
                <div class="flex justify-between gap-4">
                  <dt class="capitalize" style="color: var(--color-text-muted);">{day}</dt>
                  <dd style="font-weight: 500;">{h}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
